{
  "expo": {
    "name": "GreekPay",
    "slug": "greekpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "greekpay",
    "privacy": "https://greekpay.org/privacy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#214384"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.greekpay.member",
      "infoPlist": {
        "NSCameraUsageDescription": "GreekPay needs camera access to photograph receipts for reimbursement requests.",
        "NSPhotoLibraryUsageDescription": "GreekPay needs photo library access to upload receipts for reimbursement requests.",
        "NSFaceIDUsageDescription": "GreekPay uses Face ID to securely unlock the app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#214384"
      },
      "package": "com.greekpay.member"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GreekPay to access your photos to upload receipts.",
          "cameraPermission": "Allow GreekPay to use your camera to photograph receipts."
        }
      ],
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#214384"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.greekpay",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
